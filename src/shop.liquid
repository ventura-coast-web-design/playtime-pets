---
layout: base
title: Shop
---

<div class="shop-page">
  <div class="shop-page__container">
    <!-- Radio Button Controls -->
    <div class="shop-page__view-selector">
      <div class="shop-page__radio-group">
        <label class="shop-page__radio-label">
          <input type="radio" name="shop-view" value="shop1" class="shop-page__radio" checked>
          <span class="shop-page__radio-text">View 1</span>
        </label>
        <label class="shop-page__radio-label">
          <input type="radio" name="shop-view" value="shop2" class="shop-page__radio">
          <span class="shop-page__radio-text">View 2</span>
        </label>
        <label class="shop-page__radio-label">
          <input type="radio" name="shop-view" value="shop3" class="shop-page__radio">
          <span class="shop-page__radio-text">View 3</span>
        </label>
      </div>
    </div>

    <!-- View 1 Content -->
    <div class="shop-view shop-view--1" data-view="shop1">
      <div class="shop-view__content">
        <!-- Shop Header -->
        <div class="shop-view__header">
          <div class="shop-view__header-content">
            <h1 class="shop-view__title">All Products</h1>
            <p class="shop-view__product-count">{{ products | size }} products</p>
          </div>
        </div>

        <!-- Filters and Sort Bar -->
        <div class="shop-view__toolbar">
          <div class="shop-view__filters">
            <button class="shop-view__filter-btn" type="button">
              <span>Filter</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2 4h12M4 8h8M6 12h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
          <div class="shop-view__sort">
            <label for="sort-select" class="shop-view__sort-label">Sort by:</label>
            <select id="sort-select" class="shop-view__sort-select">
              <option value="featured">Featured</option>
              <option value="price-low">Price: Low to High</option>
              <option value="price-high">Price: High to Low</option>
              <option value="name-asc">Name: A-Z</option>
              <option value="name-desc">Name: Z-A</option>
            </select>
          </div>
        </div>

        <!-- Product Grid -->
        <div class="shop-view__grid">
          {% for product in products %}
          <a href="/shop/{{ product.id }}" class="shop-card">
            <div class="shop-card__image-wrapper">
              <img src="{{ product.image }}" alt="{{ product.title }}" loading="lazy">
              {% if product.comparePrice %}
              <span class="shop-card__badge">Sale</span>
              {% endif %}
            </div>
            <div class="shop-card__content">
              <h3 class="shop-card__title">{{ product.title }}</h3>
              <p class="shop-card__description">{{ product.description }}</p>
              <div class="shop-card__footer">
                <div class="shop-card__price-wrapper">
                  {% if product.comparePrice %}
                  <span class="shop-card__price shop-card__price--sale">${{ product.price | round: 2 }}</span>
                  <span class="shop-card__price shop-card__price--compare">${{ product.comparePrice | round: 2 }}</span>
                  {% else %}
                  <span class="shop-card__price">${{ product.price | round: 2 }}</span>
                  {% endif %}
                </div>
                <button class="shop-card__button" type="button">Add to Cart</button>
              </div>
            </div>
          </a>
          {% endfor %}
        </div>

        <!-- Empty State (if no products) -->
        {% if products.size == 0 %}
        <div class="shop-view__empty">
          <p>No products found.</p>
        </div>
        {% endif %}
      </div>
    </div>

    <!-- View 2 Content -->
    <div class="shop-view shop-view--2" data-view="shop2" style="display: none;">
      <div class="shop-view__content">
        <!-- Category Navigation -->
        <div class="shop-view__categories">
          <div class="shop-view__category-item shop-view__category-item--active">
            <div class="shop-view__category-icon">🆕</div>
            <span class="shop-view__category-name">New!</span>
          </div>
          <div class="shop-view__category-item">
            <div class="shop-view__category-icon">🐰</div>
            <span class="shop-view__category-name">Easter</span>
          </div>
          <div class="shop-view__category-item">
            <div class="shop-view__category-icon">💝</div>
            <span class="shop-view__category-name">Valentine's Day</span>
          </div>
          <div class="shop-view__category-item">
            <div class="shop-view__category-icon">🍀</div>
            <span class="shop-view__category-name">St. Pup's Day</span>
          </div>
          <div class="shop-view__category-item">
            <div class="shop-view__category-icon">🛒</div>
            <span class="shop-view__category-name">Grocery Store</span>
          </div>
          <div class="shop-view__category-item">
            <div class="shop-view__category-icon">🌸</div>
            <span class="shop-view__category-name">Spring On The Farm</span>
          </div>
          <div class="shop-view__category-item">
            <div class="shop-view__category-icon">🏈</div>
            <span class="shop-view__category-name">Puppy Bowl</span>
          </div>
          <div class="shop-view__category-item">
            <div class="shop-view__category-icon">🏀</div>
            <span class="shop-view__category-name">Mutt Madness</span>
          </div>
        </div>

        <!-- Shop All Banner -->
        <div class="shop-view__banner">
          <div class="shop-view__banner-decoration">
            <div class="shop-view__banner-dot"></div>
            <div class="shop-view__banner-dot"></div>
            <div class="shop-view__banner-dot"></div>
            <div class="shop-view__banner-dot"></div>
            <div class="shop-view__banner-dot"></div>
            <div class="shop-view__banner-squiggle"></div>
            <div class="shop-view__banner-squiggle"></div>
          </div>
          <h1 class="shop-view__banner-text">SHOP ALL</h1>
        </div>

        <!-- Filter Options -->
        <div class="shop-view__filters">
          <button class="shop-view__filter-pill">Sort</button>
          <button class="shop-view__filter-pill">Product Type</button>
          <button class="shop-view__filter-pill">Durability</button>
          <button class="shop-view__filter-pill">Play Style</button>
          <button class="shop-view__filter-pill">Toy Size</button>
          <button class="shop-view__filter-pill">Treat Type</button>
          <button class="shop-view__filter-pill">Protein</button>
          <button class="shop-view__filter-pill">Price</button>
          <button class="shop-view__filter-pill">Partnership</button>
        </div>

        <!-- Product Grid -->
        <div class="shop-view__grid">
          {% for product in products %}
          <div class="shop-view__product-card">
            <a href="/shop/{{ product.id }}" class="shop-view__product-link">
              <div class="shop-view__product-image">
                <img src="{{ product.image }}" alt="{{ product.title }}" loading="lazy">
                {% if product.comparePrice %}
                <div class="shop-view__sale-badge">
                  {% assign diff = product.comparePrice | minus: product.price %}
                  {% assign savings = diff | times: 100 | divided_by: product.comparePrice %}
                  SAVE {{ savings }}%
                </div>
                {% endif %}
                {% if product.comparePrice %}
                <div class="shop-view__on-sale-badge">ON SALE</div>
                {% endif %}
              </div>
            </a>
            
            <div class="shop-view__product-info">
              <h3 class="shop-view__product-title">{{ product.title }}</h3>
              
              {% if product.tags contains "durable" or product.tags contains "super" %}
              <div class="shop-view__product-size">2 SIZES</div>
              {% endif %}
              
              <div class="shop-view__product-price-row">
                <div class="shop-view__product-price">
                  {% if product.comparePrice %}
                  <span class="shop-view__price-current">${{ product.price }}</span>
                  <span class="shop-view__price-original">${{ product.comparePrice }}</span>
                  {% else %}
                  <span class="shop-view__price-current">${{ product.price }}</span>
                  {% endif %}
                </div>
                <button class="shop-view__add-button" type="button" onclick="event.preventDefault();">
                  <span>+</span> Add
                </button>
              </div>
            </div>
          </div>
          {% endfor %}
        </div>

        <!-- Empty State -->
        {% if products.size == 0 %}
        <div class="shop-view__empty">
          <p>No products found.</p>
        </div>
        {% endif %}
      </div>
    </div>

    <!-- View 3 Content -->
    <div class="shop-view shop-view--3" data-view="shop3" style="display: none;">
      <div class="shop-view__content">
        <!-- Product Grid -->
        <div class="shop-view__grid">
          {% for product in products %}
          <div class="shop-view__product-card">
            <a href="/shop/{{ product.id }}" class="shop-view__product-link">
              <div class="shop-view__product-image">
                <img src="{{ product.image }}" alt="{{ product.title }}" loading="lazy">
                {% if product.comparePrice %}
                <span class="shop-view__sale-badge">Sale</span>
                {% endif %}
              </div>
            </a>
            
            <div class="shop-view__product-info">
              <div class="shop-view__product-type">TOY</div>
              <h3 class="shop-view__product-title">{{ product.title }}</h3>
              
              <div class="shop-view__product-price">
                {% if product.comparePrice %}
                <span class="shop-view__price-original">${{ product.comparePrice }}</span>
                <span class="shop-view__price-current">${{ product.price }}</span>
                {% else %}
                <span class="shop-view__price-current">${{ product.price }}</span>
                {% endif %}
              </div>
              
              <!-- Color/Pattern Variations -->
              <div class="shop-view__variations">
                <div class="shop-view__variation-option shop-view__variation-option--active" style="background: linear-gradient(135deg, #87CEEB 0%, #E0F6FF 50%, #FFFFFF 100%); border: 2px solid #26335F;"></div>
                <div class="shop-view__variation-option" style="background: radial-gradient(circle, #000000 20%, transparent 20%), radial-gradient(circle, #000000 20%, transparent 20%), #FFFFFF; background-size: 12px 12px; background-position: 0 0, 6px 6px;"></div>
                <div class="shop-view__variation-option" style="background: linear-gradient(45deg, #FFB6C1 25%, #FFA500 25%, #FFA500 50%, #FFB6C1 50%, #FFB6C1 75%, #FFA500 75%); background-size: 16px 16px;"></div>
                <div class="shop-view__variation-option" style="background: linear-gradient(135deg, #228B22 0%, #40E0D0 100%);"></div>
                <div class="shop-view__variation-option" style="background: radial-gradient(circle, #FFFFFF 30%, transparent 30%), #DC143C; background-size: 20px 20px;"></div>
                <div class="shop-view__variation-option" style="background: #8B4513;"></div>
              </div>
            </div>
          </div>
          {% endfor %}
        </div>

        <!-- Shop All Button -->
        <div class="shop-view__shop-all">
          <button class="shop-view__shop-all-btn">
            <span>SHOP ALL</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor"/>
            </svg>
          </button>
        </div>

        <!-- Informational Banner -->
        <div class="shop-view__banner">
          <div class="shop-view__banner-content">
            <span>PLAY TIME</span>
            <span class="shop-view__banner-separator">✦</span>
            <span>FUN TIME</span>
            <span class="shop-view__banner-separator">✦</span>
            <span>HAPPY PETS</span>
          </div>
        </div>

        <!-- Shop by Collection Section -->
        <div class="shop-view__collections">
          <h2 class="shop-view__collections-title">Shop by Collection</h2>
          <div class="shop-view__collections-grid">
            <div class="shop-view__collection-item">
              <div class="shop-view__collection-image" style="background: linear-gradient(135deg, #FF6B9D 0%, #C44569 100%);"></div>
              <h3 class="shop-view__collection-name">Interactive Toys</h3>
            </div>
            <div class="shop-view__collection-item">
              <div class="shop-view__collection-image" style="background: linear-gradient(135deg, #4ECDC4 0%, #44A08D 100%);"></div>
              <h3 class="shop-view__collection-name">Plush Friends</h3>
            </div>
            <div class="shop-view__collection-item">
              <div class="shop-view__collection-image" style="background: linear-gradient(135deg, #FBD786 0%, #F7971E 100%);"></div>
              <h3 class="shop-view__collection-name">Outdoor Fun</h3>
            </div>
          </div>
        </div>

        <!-- Empty State -->
        {% if products.size == 0 %}
        <div class="shop-view__empty">
          <p>No products found.</p>
        </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script src="/assets/js/shop-view-switcher.js"></script>
