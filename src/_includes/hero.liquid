<section class="hero" aria-label="Hero promotion">
  <div class="hero__inner">
    <div class="hero__visual">
      <img src="/assets/images/hero-image.jpeg" alt="Happy dog with pet product" />
    </div>
    <div class="hero__promo">
      <div class="hero__promo-blob" aria-hidden="true"></div>
      <div class="hero__promo-content">
        <p class="hero__promo-deal">In celebration of our new online store</p>
        <h1 class="hero__promo-title">
          <span class="hero__promo-title-line">Opening Sale</span>
          <span class="hero__promo-title-line">Savings Are Here!</span>
        </h1>
        <a href="/shop" class="hero__cta">Shop Now</a>
      </div>
    </div>
  </div>
</section>

<section class="hero-categories" aria-label="Shop by category">
  <div class="hero-categories__inner">
    <h2 class="hero-categories__title">Shop by Category</h2>
    <ul class="hero-categories__list">
      <li><a href="/collections/new" class="hero-categories__item"><span class="hero-categories__icon" aria-hidden="true"><i class="fa-solid fa-cat"></i></span><span>New</span></a></li>
      <li><a href="/collections/walk" class="hero-categories__item"><span class="hero-categories__icon" aria-hidden="true"><i class="fa-solid fa-dog"></i></span><span>Walk</span></a></li>
      <li><a href="/collections/wear" class="hero-categories__item"><span class="hero-categories__icon" aria-hidden="true"><i class="fa-solid fa-tshirt"></i></span><span>Wear</span></a></li>
      <li><a href="/collections/sleep" class="hero-categories__item"><span class="hero-categories__icon" aria-hidden="true"><i class="fa-solid fa-bed"></i></span><span>Sleep</span></a></li>
      <li><a href="/collections/play" class="hero-categories__item"><span class="hero-categories__icon" aria-hidden="true"><i class="fa-solid fa-baseball"></i></span><span>Play</span></a></li>
      <li><a href="/collections/bundles" class="hero-categories__item"><span class="hero-categories__icon" aria-hidden="true"><i class="fa-solid fa-box"></i></span><span>Bundles</span></a></li>
      <li><a href="/sale" class="hero-categories__item"><span class="hero-categories__icon" aria-hidden="true"><i class="fa-solid fa-tag"></i></span><span>Sale</span></a></li>
    </ul>
  </div>
</section>
